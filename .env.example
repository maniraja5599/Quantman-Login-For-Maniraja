# Copy to .env and fill in your values. Never commit .env.

# Flattrade
FLATTRADE_CLIENT_ID=your_client_id
FLATTRADE_USER_ID=your_user_id
FLATTRADE_PASSWORD=your_password
FLATTRADE_TOTP=your_totp_or_dob

# Kotak Neo (popup: Validate → TOTP → Validate TOTP → MPIN → Validate MPIN)
KOTAKNEO_CLIENT_ID=your_client_id
KOTAKNEO_USER_ID=your_mobile_number
KOTAKNEO_TOTP=your_base32_secret_from_QR
KOTAKNEO_MPIN=your_mpin

# Telegram notifications
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
